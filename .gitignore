# Python
__pycache__/
*.py[cod]
.venv/
venv/

# Unity
Library/
Temp/
Obj/
Build/
Builds/
Logs/
UserSettings/

# Local VRM models and their imported assets may have redistribution restrictions.
avatar-unity/Assets/Models/
avatar-unity/Assets/Models.meta

# Local preview scene directly references an ignored VRM model.
avatar-unity/Assets/Scenes/AvatarDemo.unity
avatar-unity/Assets/Scenes/AvatarDemo.unity.meta

# Keep server logging utility code even on case-insensitive filesystems where
# the Unity Logs/ rule can match server/logs/.
!server/logs/
!server/logs/**
server/logs/__pycache__/
server/logs/**/*.log
server/logs/*.log
server/runtime/

# Environment and local secrets
.env
.env.*
server/config/debug.yaml
server/config/prod.yaml

# OS/editor
.DS_Store
Thumbs.db
.vscode/
.idea/
